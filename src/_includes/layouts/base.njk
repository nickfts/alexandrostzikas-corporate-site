<!DOCTYPE html>
<html lang="el">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if pageTitle %}{{ pageTitle }}{% else %}{{ siteData.settings.company_name }}{% endif %}</title>
    <meta
      name="description"
      content="{% if pageDescription %}{{ pageDescription }}{% elseif siteData.settings.default_meta_description %}{{ siteData.settings.default_meta_description }}{% else %}{{ meta.defaultDescription }}{% endif %}"
    />
    {% if siteData.settings.google_site_verification %}
    <meta name="google-site-verification" content="{{ siteData.settings.google_site_verification }}" />
    {% endif %}
    {% if noindex %}
    <meta name="robots" content="noindex, nofollow" />
    {% endif %}
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="{{ meta.locale }}" />
    <meta property="og:title" content="{% if pageTitle %}{{ pageTitle }}{% else %}{{ siteData.settings.company_name }}{% endif %}" />
    <meta
      property="og:description"
      content="{% if pageDescription %}{{ pageDescription }}{% elseif siteData.settings.default_meta_description %}{{ siteData.settings.default_meta_description }}{% else %}{{ meta.defaultDescription }}{% endif %}"
    />
    <meta
      property="og:image"
      content="{% if pageImage %}{{ pageImage }}{% elseif siteData.settings.og_image %}{{ siteData.settings.og_image }}{% else %}{{ meta.defaultImage }}{% endif %}"
    />
    <meta property="og:url" content="{{ meta.siteUrl }}{{ page.url }}" />
    <link rel="canonical" href="{{ meta.siteUrl }}{{ page.url }}" />
    <link rel="icon" type="image/x-icon" href="/assets/icons/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/icons/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preload" href="/assets/css/styles.css" as="style" />
    <link rel="preload" href="/assets/fonts/AkaAcidDosis-Regular.otf" as="font" type="font/otf" crossorigin />
    <link rel="preload" href="/assets/fonts/AkaAcidDosis-SemiBold.otf" as="font" type="font/otf" crossorigin />
    <link rel="preload" href="/assets/fonts/AC-Fifindrel_Unicode.otf" as="font" type="font/otf" crossorigin />
    <link rel="stylesheet" href="/assets/css/styles.css" />
    {% set gaMeasurementId = (siteData.settings.ga4_measurement_id or '') | trim %}
    {% set analyticsEnabled = true if (siteData.settings.enable_analytics and gaMeasurementId) else false %}
    {% set analyticsConfig = { "enabled": analyticsEnabled, "measurementId": gaMeasurementId } %}
    <script>window.__SITE_ANALYTICS_CONFIG__ = {{ analyticsConfig | json | safe }};</script>
    <script defer src="/assets/js/site.js"></script>
    {% if page.url == '/el/leaflets/' %}
    <script defer src="/assets/js/leaflets-viewer.js"></script>
    {% endif %}
    {% set orgSchema = {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": siteData.settings.company_name,
      "url": meta.siteUrl,
      "logo": meta.siteUrl + (siteData.settings.logo_path or '/assets/branding/logo.png'),
      "email": siteData.settings.email,
      "telephone": siteData.settings.primary_phone,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": siteData.settings.address
      }
    } %}
    <script type="application/ld+json">{{ orgSchema | json | safe }}</script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Μετάβαση στο περιεχόμενο</a>
    <header class="site-header">
      <div class="container header-inner">
        <a class="brand-link" href="/el/" aria-label="Αρχική">
            <img
            src="{% if siteData.settings.logo_path %}{{ siteData.settings.logo_path }}{% else %}/assets/branding/logo.png{% endif %}"
            alt="{{ siteData.settings.company_name }}"
            class="brand-logo"
            width="180"
            height="56"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </a>
        <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="main-nav">
          <span class="menu-toggle-line"></span>
          <span class="menu-toggle-line"></span>
          <span class="menu-toggle-line"></span>
          <span class="sr-only">Άνοιγμα μενού</span>
        </button>
        <nav id="main-nav" class="main-nav" aria-label="Κύρια πλοήγηση">
          <ul class="nav-list">
            <li><a href="/el/" {% if navKey == 'home' %}aria-current="page"{% endif %}>Αρχική</a></li>
            <li><a href="/el/about/" {% if navKey == 'about' %}aria-current="page"{% endif %}>Η Επιχείρηση</a></li>
            <li class="nav-has-dropdown">
              <button class="nav-dropdown-toggle" type="button" aria-expanded="false" aria-controls="products-dropdown">
                Κατηγορίες Προϊόντων
              </button>
              <div id="products-dropdown" class="nav-dropdown" hidden>
                {% if siteData.navCategories.length %}
                <ul>
                  {% for category in siteData.navCategories %}
                  <li class="dropdown-category">
                    <a href="/el/products/{{ category.slug }}/">{{ category.menu_title }}</a>
                    {% if category.subcategories.length %}
                    <ul>
                      {% for subcategory in category.subcategories %}
                      <li>
                        <a href="/el/products/{{ category.slug }}/{{ subcategory.slug }}/">{{ subcategory.title }}</a>
                      </li>
                      {% endfor %}
                    </ul>
                    {% endif %}
                  </li>
                  {% endfor %}
                </ul>
                {% else %}
                <p class="dropdown-empty">Δεν υπάρχουν ακόμη κατηγορίες.</p>
                {% endif %}
              </div>
            </li>
            <li><a href="/el/leaflets/" {% if navKey == 'leaflets' %}aria-current="page"{% endif %}>Φυλλάδια</a></li>
            <li><a href="/el/contact/" {% if navKey == 'contact' %}aria-current="page"{% endif %}>Επικοινωνία</a></li>
            <li class="lang-item">
              <div class="lang-switch" aria-label="Επιλογή γλώσσας">
                <a href="/el/" class="lang-link is-active" aria-current="true">EL</a>
                <a href="/en/" class="lang-link">EN</a>
              </div>
            </li>
          </ul>
        </nav>
      </div>
    </header>

    <main id="main-content">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <section>
          <h2>Η Επιχείρηση</h2>
          <p>{{ siteData.settings.company_name }}</p>
          <p>
            <a
              href="{{ siteData.settings.google_maps_action_url or siteData.settings.google_maps_url or 'https://maps.google.com/' }}"
              target="_blank"
              rel="noopener noreferrer"
              data-track-event="google_maps_click"
              data-track-label="footer_address"
            >
              {{ siteData.settings.address }}
            </a>
          </p>
          <p class="phone-with-viber">
            <a href="{{ siteData.settings.primary_phone_href or ('tel:' + (siteData.settings.primary_phone | replace(' ', ''))) }}">{{ siteData.settings.primary_phone }}</a>
            {% if siteData.settings.primary_phone_viber_href %}
            <a
              class="viber-link"
              href="{{ siteData.settings.primary_phone_viber_href }}"
              data-track-event="contact_viber_click"
              data-track-label="footer_primary_phone_viber"
              aria-label="Μήνυμα στο Viber (κύριο τηλέφωνο)"
            >
              <img class="viber-icon" src="/assets/icons/viber.png" alt="" loading="lazy" decoding="async" />
              <span class="sr-only">Viber</span>
            </a>
            {% endif %}
          </p>
          {% if siteData.settings.enable_second_phone and siteData.settings.second_phone %}
          <p class="phone-with-viber">
            <a href="{{ siteData.settings.second_phone_href or ('tel:' + (siteData.settings.second_phone | replace(' ', ''))) }}">{{ siteData.settings.second_phone }}</a>
            {% if siteData.settings.second_phone_viber_href %}
            <a
              class="viber-link"
              href="{{ siteData.settings.second_phone_viber_href }}"
              data-track-event="contact_viber_click"
              data-track-label="footer_second_phone_viber"
              aria-label="Μήνυμα στο Viber (δεύτερο τηλέφωνο)"
            >
              <img class="viber-icon" src="/assets/icons/viber.png" alt="" loading="lazy" decoding="async" />
              <span class="sr-only">Viber</span>
            </a>
            {% endif %}
          </p>
          {% endif %}
          <p>
            <a href="{{ siteData.settings.email_href or ('mailto:' + siteData.settings.email) }}">{{ siteData.settings.email }}</a>
          </p>
        </section>
        <section>
          <h2>Γρήγοροι Σύνδεσμοι</h2>
          <ul class="footer-links">
            <li><a href="/el/about/">Η Επιχείρηση</a></li>
            <li><a href="/el/products/">Προϊόντα</a></li>
            <li><a href="/el/leaflets/">Φυλλάδια</a></li>
            <li><a href="/el/contact/">Επικοινωνία</a></li>
            <li><a href="/el/privacy/">Πολιτική Απορρήτου</a></li>
            <li><a href="/el/cookies/">Πολιτική Cookies</a></li>
          </ul>
        </section>
        <section>
          <h2>Ακολουθήστε μας στα Social</h2>
          <ul class="footer-links">
            <li><a href="{{ siteData.settings.social_facebook or '#' }}" target="_blank" rel="noopener noreferrer">Facebook</a></li>
            <li><a href="{{ siteData.settings.social_instagram or '#' }}" target="_blank" rel="noopener noreferrer">Instagram</a></li>
            <li><a href="{{ siteData.settings.social_tiktok or siteData.settings.social_linkedin or '#' }}" target="_blank" rel="noopener noreferrer">TikTok</a></li>
          </ul>
        </section>
      </div>
      <div class="container footer-legal">
        <small><span class="footer-copyright-line">{{ meta.currentYear }} {{ siteData.settings.company_name }}.</span><span class="footer-rights-line">Με επιφύλαξη παντός δικαιώματος.</span></small>
      </div>
    </footer>

    {% set quickPhoneHref = siteData.settings.primary_phone_href or ('tel:' + (siteData.settings.primary_phone | replace(' ', ''))) %}
    {% set quickEmailHref = siteData.settings.email_href or ('mailto:' + siteData.settings.email) %}
    {% set quickMapsHref = siteData.settings.google_maps_action_url or siteData.settings.google_maps_url or 'https://maps.google.com/' %}
    {% set quickViberHref = siteData.settings.primary_phone_viber_href %}
    {% if quickPhoneHref or quickEmailHref or quickMapsHref or quickViberHref %}
    <div class="mobile-quick-actions" data-mobile-quick-actions>
      <button
        type="button"
        class="mobile-quick-actions-toggle"
        data-mobile-quick-toggle
        aria-expanded="false"
        aria-controls="mobile-quick-actions-panel"
      >
        <img class="mobile-quick-actions-icon" src="/assets/icons/info.png" alt="" loading="lazy" decoding="async" />
        <span class="sr-only">Quick actions</span>
      </button>
      <div id="mobile-quick-actions-panel" class="mobile-quick-actions-panel" data-mobile-quick-panel hidden>
        {% if quickMapsHref %}
        <a
          class="mobile-quick-action-icon"
          href="{{ quickMapsHref }}"
          target="_blank"
          rel="noopener noreferrer"
          data-track-event="google_maps_click"
          data-track-label="quick_actions_maps"
          aria-label="Maps"
        >
          <img src="/assets/icons/map.png" alt="" loading="lazy" decoding="async" />
          <span class="sr-only">Maps</span>
        </a>
        {% endif %}
        {% if quickEmailHref %}
        <a
          class="mobile-quick-action-icon"
          href="{{ quickEmailHref }}"
          data-track-event="contact_email_click"
          data-track-label="quick_actions_email"
          aria-label="Email"
        >
          <img src="/assets/icons/mail.png" alt="" loading="lazy" decoding="async" />
          <span class="sr-only">Email</span>
        </a>
        {% endif %}
        {% if quickViberHref %}
        <a
          class="mobile-quick-action-icon"
          href="{{ quickViberHref }}"
          data-track-event="contact_viber_click"
          data-track-label="quick_actions_viber"
          aria-label="Viber"
        >
          <img src="/assets/icons/viber.png" alt="" loading="lazy" decoding="async" />
          <span class="sr-only">Viber</span>
        </a>
        {% endif %}
        {% if quickPhoneHref %}
        <a
          class="mobile-quick-action-icon"
          href="{{ quickPhoneHref }}"
          data-track-event="contact_phone_click"
          data-track-label="quick_actions_phone"
          aria-label="Phone"
        >
          <img src="/assets/icons/phone.png" alt="" loading="lazy" decoding="async" />
          <span class="sr-only">Phone</span>
        </a>
        {% endif %}
      </div>
    </div>
    {% endif %}

    {% if analyticsEnabled %}
    <section class="cookie-banner" data-cookie-banner hidden aria-label="Cookies consent">
      <div class="cookie-banner-panel">
        <p>
          Χρησιμοποιούμε προαιρετικά cookies analytics για ανώνυμη μέτρηση επισκεψιμότητας.
          Μπορείτε να επιλέξετε αποδοχή ή απόρριψη.
          <a href="/el/cookies/">Πολιτική Cookies</a>
        </p>
        <div class="cookie-banner-actions">
          <button type="button" class="btn btn-solid" data-cookie-accept>Αποδοχή</button>
          <button type="button" class="btn btn-outline" data-cookie-reject>Απόρριψη</button>
        </div>
      </div>
    </section>
    {% endif %}
  </body>
</html>
