---
layout: layouts/base.njk
permalink: /el/contact/index.html
navKey: contact
eleventyComputed:
  pageTitle: "{{ siteData.pages.contact.seo_title or (siteData.settings.company_name + ' | Επικοινωνία') }}"
  pageDescription: "{{ siteData.pages.contact.seo_description or siteData.settings.default_meta_description or meta.defaultDescription }}"
  pageImage: "{{ siteData.pages.contact.og_image or siteData.settings.og_image or meta.defaultImage }}"
---
<section class="section section-page-head">
  <div class="container">
    <p class="eyebrow">Επικοινωνία</p>
    <h1>{{ siteData.pages.contact.title }}</h1>
    <p>{{ siteData.pages.contact.intro }}</p>
  </div>
</section>

<section class="section section-tight">
  <div class="container">
    <div class="contact-grid">
      <article class="contact-card">
        <h2>Τηλέφωνο</h2>
        <p><a href="tel:{{ siteData.settings.primary_phone | replace(' ', '') }}">{{ siteData.settings.primary_phone }}</a></p>
        {% if siteData.settings.enable_second_phone and siteData.settings.second_phone %}
        <p><a href="tel:{{ siteData.settings.second_phone | replace(' ', '') }}">{{ siteData.settings.second_phone }}</a></p>
        {% endif %}
      </article>
      <article class="contact-card">
        <h2>Email</h2>
        <p><a href="mailto:{{ siteData.settings.email }}">{{ siteData.settings.email }}</a></p>
      </article>
      <article class="contact-card">
        <h2>Διεύθυνση</h2>
        <p>{{ siteData.settings.address }}</p>
      </article>
      <article class="contact-card">
        <h2>Website</h2>
        <p><a href="{{ siteData.settings.website_url or '#' }}" target="_blank" rel="noopener noreferrer">{{ siteData.settings.website_label or siteData.settings.website_url or 'example.com' }}</a></p>
      </article>
      {% if siteData.settings.enable_hours and siteData.settings.business_hours %}
      <article class="contact-card">
        <h2>Ωράριο</h2>
        <p>{{ siteData.settings.business_hours }}</p>
      </article>
      {% endif %}
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="map-frame">
      <iframe
        src="{{ siteData.settings.map_embed_url or 'https://www.google.com/maps?q=Thessaloniki&output=embed' }}"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
        title="Χάρτης τοποθεσίας"
      ></iframe>
    </div>
    <p class="map-action">
      <a class="btn btn-solid" href="{{ siteData.settings.google_maps_url or 'https://maps.google.com/' }}" target="_blank" rel="noopener noreferrer">
        Δείτε μας στο Google Maps
      </a>
    </p>
  </div>
</section>
