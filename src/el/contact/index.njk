---
layout: layouts/base.njk
permalink: /el/contact/index.html
navKey: contact
eleventyComputed:
  pageTitle: "{{ siteData.pages.contact.seo_title or (siteData.settings.company_name + ' | Επικοινωνία') }}"
  pageDescription: "{{ siteData.pages.contact.seo_description or siteData.settings.default_meta_description or meta.defaultDescription }}"
  pageImage: "{{ siteData.pages.contact.og_image or siteData.settings.og_image or meta.defaultImage }}"
---
<section class="section section-page-head">
  <div class="container">
    <p class="eyebrow">Επικοινωνία</p>
    <h1>{{ siteData.pages.contact.title }}</h1>
    <p>{{ siteData.pages.contact.intro }}</p>
  </div>
</section>

<section class="section section-tight">
  <div class="container">
    <div class="contact-grid">
      <article class="contact-card">
        <h2>Τηλέφωνο</h2>
        <p><a href="{{ siteData.settings.primary_phone_href or ('tel:' + (siteData.settings.primary_phone | replace(' ', ''))) }}" data-track-event="contact_phone_click" data-track-label="primary_phone">{{ siteData.settings.primary_phone }}</a></p>
        {% if siteData.settings.enable_second_phone and siteData.settings.second_phone %}
        <p><a href="{{ siteData.settings.second_phone_href or ('tel:' + (siteData.settings.second_phone | replace(' ', ''))) }}" data-track-event="contact_phone_click" data-track-label="second_phone">{{ siteData.settings.second_phone }}</a></p>
        {% endif %}
      </article>
      <article class="contact-card">
        <h2>Email</h2>
        <p><a href="{{ siteData.settings.email_href or ('mailto:' + siteData.settings.email) }}" data-track-event="contact_email_click">{{ siteData.settings.email }}</a></p>
      </article>
      <article class="contact-card">
        <h2>Διεύθυνση</h2>
        <p>{{ siteData.settings.address }}</p>
      </article>
      <article class="contact-card">
        <h2>Website</h2>
        <p><a href="{{ siteData.settings.website_url or '#' }}" target="_blank" rel="noopener noreferrer" data-track-event="website_click">{{ siteData.settings.website_label or siteData.settings.website_url or 'example.com' }}</a></p>
      </article>
      {% if siteData.settings.enable_hours and siteData.settings.business_hours %}
      <article class="contact-card">
        <h2>Ωράριο</h2>
        <p>{{ siteData.settings.business_hours }}</p>
      </article>
      {% endif %}
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="map-frame">
      <iframe
        src="{{ siteData.settings.map_embed_url or 'https://www.google.com/maps?q=Thessaloniki&output=embed' }}"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
        title="Χάρτης τοποθεσίας"
      ></iframe>
    </div>
    <p class="map-action">
      <a class="btn btn-solid" href="{{ siteData.settings.google_maps_action_url or siteData.settings.google_maps_url or 'https://maps.google.com/' }}" target="_blank" rel="noopener noreferrer" data-track-event="google_maps_click">
        Δείτε μας στο Google Maps
      </a>
    </p>
  </div>
</section>

{% if siteData.settings.enable_contact_form and siteData.settings.contact_form_endpoint %}
<section class="section section-tight">
  <div class="container">
    <article class="contact-card">
      <h2>Φόρμα Επικοινωνίας</h2>
      <p>Στείλτε μας το μήνυμά σας και θα επικοινωνήσουμε μαζί σας το συντομότερο δυνατό.</p>
      <form
        class="contact-form"
        method="post"
        action="{{ siteData.settings.contact_form_endpoint }}"
        data-remote-contact-form
      >
        <input type="hidden" name="_subject" value="Νέο μήνυμα από τη φόρμα επικοινωνίας" />
        <p class="contact-form-honeypot" aria-hidden="true">
          <label>Μην το συμπληρώσετε <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" /></label>
        </p>
        <div class="contact-form-grid">
          <label>
            Ονοματεπώνυμο
            <input type="text" name="name" required />
          </label>
          <label>
            Email
            <input type="email" name="email" required />
          </label>
          <label>
            Τηλέφωνο
            <input type="text" name="phone" />
          </label>
          <label>
            Θέμα
            <input type="text" name="subject" />
          </label>
        </div>
        <label>
          Μήνυμα
          <textarea name="message" rows="5" required></textarea>
        </label>
        <button type="submit" class="btn btn-solid" data-track-event="contact_form_submit_click">Αποστολή</button>
        <p class="form-status" data-form-status hidden></p>
      </form>
    </article>
  </div>
</section>
{% endif %}
